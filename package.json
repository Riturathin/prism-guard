{
  "name": "prism-guard",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "npm run dev:fixture",
    "build": "npm run build --workspaces --if-present",
    "clean": "rm -rf packages/**/dist",
    "dev": "ts-node packages/cli/src/index.ts analyze",
    "dev:fixture": "ts-node packages/cli/src/index.ts analyze --cwd fixtures/sample-react",
    "build:watch": "tsc -b --watch",
    "analyze": "node packages/cli/dist/index.js analyze",
    "analyze:fixture": "node packages/cli/dist/index.js analyze --cwd fixtures/sample-react",
    "analyze:json": "node packages/cli/dist/index.js analyze --cwd fixtures/sample-react --json",
    "analyze:html": "node packages/cli/dist/index.js analyze --cwd fixtures/sample-react --html"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "react": "^19.2.7"
  }
}
