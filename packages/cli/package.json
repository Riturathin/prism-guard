{
  "name": "@prism-guard/cli",
  "version": "1.0.3",
  "description": "Open-source static analysis CLI for React & TypeScript. Detect architecture issues, performance anti-patterns, code quality problems, and generate HTML, JSON & SARIF reports.",
  "license": "MIT",
  "author": "Ritumoni Sarma",
  "homepage": "https://github.com/Riturathin/prism-guard",
  "repository": {
    "type": "git",
    "url": "https://github.com/Riturathin/prism-guard.git"
  },
  "bugs": {
    "url": "https://github.com/Riturathin/prism-guard/issues"
  },
  "keywords": [
    "react",
    "typescript",
    "javascript",
    "frontend",
    "frontend architecture",
    "react architecture",
    "static analysis",
    "code analysis",
    "code quality",
    "react lint",
    "linter",
    "eslint alternative",
    "performance",
    "react performance",
    "bundle analysis",
    "developer tools",
    "cli",
    "ast",
    "microfrontend",
    "design system",
    "architecture",
    "quality gate",
    "sarif",
    "html report",
    "code review",
    "react analyzer",
    "typescript analyzer",
    "prism guard"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "prism-guard": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --project tsconfig.json src/index.ts"
  },
  "dependencies": {
    "@prism-guard/core": "^1.0.0",
    "@prism-guard/rules-react": "^1.0.0",
    "@prism-guard/rules-performance": "^1.0.0",
    "@prism-guard/rules-architecture": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
